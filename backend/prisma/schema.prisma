// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url=env("DATABASE_URL")
}

enum SkillCategory {
  LANGUAGE
  CS_FUNDAMENTALS
  FRONTEND
  BACKEND
  DATABASE
  FRAMEWORK
  ML_AI
  TOOLS
  CLOUD
  DATA_ANALYSIS
  DATA_VISUALIZATION
}

enum SocialPlatform {
  GITHUB
  LINKEDIN
  LEETCODE
  CODEFORCES
  CODECHEF
  HACKERRANK
  TWITTER
  INSTAGRAM
  EMAIL
  OTHER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id        String        @id @default(cuid())
  name      String        @unique
  category  SkillCategory
  imageUrl  String?

  projects      ProjectSkill[]
  certificates  CertificateSkill[]
  experiences   ExperienceSkill[]
}

enum ProjectStatus {
  COMPLETED
  ONGOING
}

model Project {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  shortDescription String
  fullDescription  String
  githubUrl        String?
  liveUrl          String?
  isVisible        Boolean       @default(true)
  featured         Boolean       @default(false)
  displayOrder     Int           @default(1)
  status           ProjectStatus

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  images           ProjectImage[]
  skills           ProjectSkill[]
}

model ProjectImage {
  id           String   @id @default(cuid())
  imageUrl     String
  displayOrder Int

  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectSkill {
  projectId String
  skillId   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([projectId, skillId])
}

model Issuer {
  id   String @id @default(cuid())
  name String @unique
  logo String?

  certificates Certificate[]
}

model Certificate {
  id              String   @id @default(cuid())
  title           String
  issuerId        String
  issuer          Issuer   @relation(fields: [issuerId], references: [id])
  credentialUrl   String
  badgeImageUrl   String?
  isVisible       Boolean  @default(true)
  featured        Boolean  @default(false)
  displayOrder    Int      @default(1)
  issueDate       DateTime
  expiryDate      DateTime?

  skills          CertificateSkill[]
}

model CertificateSkill {
  certificateId String
  skillId       String

  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  skill        Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([certificateId, skillId])
}

model Experience {
  id                String   @id @default(cuid())
  company           String
  role              String
  location          String?
  startDate         DateTime
  endDate           DateTime?
  isVisible         Boolean  @default(true)
  currentlyWorking  Boolean  @default(false)
  displayOrder      Int      @default(1)
  companyImageUrl   String?

  points            ExperiencePoint[]
  skills            ExperienceSkill[]
}

model ExperiencePoint {
  id           String      @id @default(cuid())
  content      String
  displayOrder Int

  experienceId String
  experience   Experience  @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model ExperienceSkill {
  experienceId String
  skillId      String

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  skill       Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([experienceId, skillId])
}

model Profile {
  id              String @id @default(cuid())
  name            String
  title           String
  about           String
  email           String
  phone           String?
  location        String?
  resumeUrl       String?
  profileImageUrl String?
  heroImageUrl    String?
  tagline         String?
}

model Education {
  id                  String   @id @default(cuid())
  institution         String
  degree              String
  fieldOfStudy        String
  grade               String?
  location            String?
  startDate           DateTime
  endDate             DateTime?
  currentlyStudying   Boolean  @default(false)
  institutionImageUrl String?
}

model SocialLink {
  id           String         @id @default(cuid())
  platform     SocialPlatform @unique
  url          String
  displayOrder Int
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  replied   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}